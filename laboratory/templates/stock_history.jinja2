{% extends 'layout.jinja2' %}

{% block content %}
<div class="content">
<h2><span class="smaller">Історія складу реактивів</span><br>
<span class="lead">приходи, розходи</span></h2>
<p><a href="/buy-substance" class="btn btn-primary">Приход реактивів на склад</a>
	<br>Нажміть на кнопку щоб роздрукувати цю сторінку або зберегти в .pdf файл
	<button onclick=window.print() class="btn btn-success">Друк</button></p>
<p>{{message}}</p>
{% if history %}
<table id="recipes" class="table table-bordered" style="width:100%">
  <thead>
      <tr>
          <th>Дата</th>
          <th>Реактив (речовина, індикатор)</th>
          <th>Одиниця виміру</th>
          <th>Кількість</th>
          <th>Ціна, грн.</th>
          <th>Сума, грн.</th>
          <th>Примітка</th>
      </tr>
  </thead>
  <tbody>
    {% for item in history %}
    <tr>
      <td>{{ item['creation_date'] }}</td>
      <td>{{ item['substance_name'] }}</td>
			<td>{{ item['measurement'] }}</td>
			<td>{{ item['amount'] }}</td>
			<td>{{ item['price'] }}</td>
			<td>{{ item['total_cost'] }}</td>
			<td>{{ item['notes'] }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
</div>
<script>
  $(document).ready(function() {
    $('#recipes').DataTable( {
      language: {
          search: "Пошук по таблиці",
          paginate: {
            first: "Перша",
            previous: "Попередня",
            next: "Наступна",
            last: "Остання"
          },
      }
    } );
  } );
</script>
{% endblock %}
