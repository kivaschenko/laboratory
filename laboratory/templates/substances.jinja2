{% extends "layout.jinja2" %}

{% block content %}
<div class="content">
<h2>Каталог реактивів</h2>

<table class="table">
    <thead>
        <tr>
            <th>#</th>
            <th>Назва</th>
            <th>Од. виміру</th>
            <th>Видалити</th>
        </tr>
    </thead>
    <tbody>
        {% if subs_list %}
            {% for subs in subs_list %}
        <tr>
            <td>{{ subs['id'] }}</td>
            <td>{{ subs['name'] }}</td>
            <td>{{ subs['measurement'] }}</td>
            <td><i class="glyphicon glyphicon-trash"></i><a href="/substance/{{ subs['id'] }}/delete"> Видалити</a></td>
        </tr>
            {% endfor %}
        {% else %}
        <tr>немає нічого в каталозі</tr>
        {% endif %}
    </tbody>
</table>
<a href="/add_substance" class="btn btn-default">Додати новий реактив</a>
</div>
{% endblock content %}